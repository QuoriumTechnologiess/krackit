# Copy to .env.local and fill in real values. .env.local is git-ignored.
# Recruiter shares the SAME Neon database and SAME Clerk instance as the student app
# (apps/web) and apps/admin — it does not have its own user pool. Access is gated by a local
# Recruiter row (status: APPROVED) AND Clerk publicMetadata `role: "recruiter"`, both set
# together from apps/admin's recruiter verification queue.

# Neon Postgres (same DB as apps/web)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/neondb?sslmode=require"

# Clerk (same instance/keys as apps/web)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
